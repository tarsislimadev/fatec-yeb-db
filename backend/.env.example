# Database
DATABASE_URL=postgresql://phone_list:password@localhost:5432/phone_list
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-change-in-production-minimum-32-chars
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# Server
NODE_ENV=development # Change to 'production' in production
PORT=3000 # Change to 80 in production if not using a reverse proxy
API_URL=http://localhost:3000 # Base URL for API calls, used in frontend and webhooks
FRONTEND_URL=http://localhost:5173 # URL of the frontend application, used for CORS and redirects
WEBHOOK_URL=http://localhost:3000/api/v1/webhooks # Base URL for webhooks, used in third-party integrations

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-key
SENDGRID_FROM_EMAIL=noreply@example.com

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_CALLBACK=http://localhost:3000/api/v1/auth/oauth/google/callback

# OAuth - Microsoft
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_OAUTH_CALLBACK=http://localhost:3000/api/v1/auth/oauth/microsoft/callback

# Logging
LOG_LEVEL=debug # Set to 'info' or 'error' in production

# Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# Twilio
TWILIO_ACCOUNT_SID= # Your Twilio Account SID
TWILIO_AUTH_TOKEN= # Your Twilio Auth Token
TWILIO_FROM_NUMBER= # Your Twilio phone number in E.164 format (e.g., +1234567890)

# Rate Limiting
AUTH_RATE_LIMIT_WINDOW_MS= # Time window in milliseconds for authentication rate limiting (e.g., 15 * 60 * 1000 for 15 minutes)
AUTH_RATE_LIMIT_MAX= # Maximum number of authentication attempts allowed within the time window
WRITE_RATE_LIMIT_WINDOW_MS= # Time window in milliseconds for write operations rate limiting (e.g., 15 * 60 * 1000 for 15 minutes)
WRITE_RATE_LIMIT_MAX= # Maximum number of write operations allowed within the time window
